<odoo>
    <data>
        <record id="phase_backlog" model="project.task.type">
            <field name="name">Бэклог</field>
            <field name="sequence">1</field>
            <field name="project_ids" eval="[(6, 0, [])]"/>
        </record>

        <record id="phase_spec" model="project.task.type">
            <field name="name">Спецификация и анализ</field>
            <field name="sequence">10</field>
            <field name="project_ids" eval="[(6, 0, [])]"/>
        </record>

        <record id="phase_dev" model="project.task.type">
            <field name="name">Разработка и реализация</field>
            <field name="sequence">20</field>
            <field name="project_ids" eval="[(6, 0, [])]"/>
        </record>

        <record id="phase_test" model="project.task.type">
            <field name="name">Тестирование и приемка</field>
            <field name="sequence">30</field>
            <field name="project_ids" eval="[(6, 0, [])]"/>
        </record>

        <record id="phase_delivered" model="project.task.type">
            <field name="name">Доставлено</field>
            <field name="sequence">40</field>
            <field name="project_ids" eval="[(6, 0, [])]"/>
        </record>

        <record id="phase_archive" model="project.task.type">
            <field name="name">Архив</field>
            <field name="sequence">50</field>
            <field name="fold" eval="True"/>
            <field name="project_ids" eval="[(6, 0, [])]"/>
        </record>
    </data>
</odoo>