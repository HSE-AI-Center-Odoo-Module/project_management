<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Activate Russian language automatically -->
        <record id="base.lang_ru" model="res.lang">
            <field name="active">True</field>
        </record>

        <!-- Set Russian as default for main company -->
        <record id="base.main_partner" model="res.partner">
            <field name="lang">ru_RU</field>
        </record>

        <!-- Set Russian as system default -->
        <record id="default_lang_setting" model="ir.config_parameter">
            <field name="key">base.default_lang</field>
            <field name="value">ru_RU</field>
        </record>
    </data>
</odoo>