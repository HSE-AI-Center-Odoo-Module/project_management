<odoo>
    <record id="role_expert" model="university.project.role">
        <field name="name">Эксперт</field>
        <field name="code">expert</field>
        <field name="sequence">1</field>
    </record>

    <record id="role_researcher" model="university.project.role">
        <field name="name">Исследователь</field>
        <field name="code">researcher</field>
        <field name="sequence">2</field>
    </record>

    <record id="role_developer" model="university.project.role">
        <field name="name">Разработчик</field>
        <field name="code">developer</field>
        <field name="sequence">3</field>
    </record>

    <record id="role_analyst" model="university.project.role">
        <field name="name">Аналитик</field>
        <field name="code">analyst</field>
        <field name="sequence">4</field>
    </record>

    <record id="role_intern" model="university.project.role">
        <field name="name">Стажёр</field>
        <field name="code">intern</field>
        <field name="sequence">5</field>
    </record>
</odoo>