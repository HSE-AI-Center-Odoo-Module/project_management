<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="rule_project_visibility_employee" model="ir.rule">
            <field name="name">Project: Read-Only Visibility for AI Center Employee</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="groups" eval="[(4, ref('project_management.employee'))]"/>
            <field name="domain_force">
                ['|', '|',
                    ('member_user_ids', 'in', user.id)
                ]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_project_manager_edit_access" model="ir.rule">
            <field name="name">Project: Edit Access for Designated PM</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="groups" eval="[(4, ref('project_management.employee'))]"/>
            <field name="domain_force">
                [('project_manager_id', '=', user.id)]
            </field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_project_visibility_admin" model="ir.rule">
            <field name="name">Project: Full Visibility for AI Center Admin</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="groups" eval="[(4, ref('project_management.administrator'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_task_visibility_employee" model="ir.rule">
            <field name="name">Task: Visibility for AI Center Employee</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('project_management.employee'))]"/>
            <field name="domain_force">[('user_ids', 'in', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_task_visibility_manager" model="ir.rule">
            <field name="name">Task: Visibility for Project Manager</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('project_management.employee'))]"/>
            <field name="domain_force">[('project_id.project_manager_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_task_visibility_admin" model="ir.rule">
            <field name="name">Task: Full Visibility for AI Center Admin</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="groups" eval="[(4, ref('project_management.administrator'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <function name="write" model="ir.rule">
            <function name="search" model="ir.rule">
                <value eval="[('id', '=', ref('project.project_public_members_rule'))]"/>
            </function>
            <value eval="{'active': False}"/>
        </function>

    </data>
</odoo>