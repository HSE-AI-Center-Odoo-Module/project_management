<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Assign administrator group to default admin user on install -->
    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('project_management.administrator'))]"/>
    </record>

    <!-- Set AI Centre projects as home page for admin -->
    <record id="base.user_admin" model="res.users">
        <field name="action_id" ref="project_management.action_university_project_all"/>
    </record>
</odoo>
