<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="project_management.CommentThread">
        <div class="pm-comment-thread w-100">

            <!-- ===== СПИСОК ===== -->
            <div class="pm-comment-list mb-3">

                <t t-if="state.loading">
                    <div class="text-muted text-center py-4">
                        <i class="fa fa-spinner fa-spin me-2"/>Загрузка...
                    </div>
                </t>

                <t t-elif="state.comments.length === 0">
                    <div class="text-muted text-center py-4">
                        <i class="fa fa-comments-o fa-2x mb-2 d-block"/>
                        Комментариев пока нет
                    </div>
                </t>

                <t t-else="">
                    <t t-foreach="state.comments" t-as="c" t-key="c.id">
                        <div t-attf-class="d-flex mb-3 w-100 {{ isOwn(c) ? 'flex-row-reverse' : '' }}">

                            <!-- Аватар -->
                            <div t-attf-class="pm-avatar flex-shrink-0 {{ isOwn(c) ? 'ms-2 pm-avatar-self' : 'me-2' }}">
                                <t t-esc="avatarLetter(c)"/>
                            </div>

                            <!-- Тело -->
                            <div class="pm-bubble-wrap d-flex flex-column"
                                 t-attf-style="{{ isOwn(c) ? 'align-items:flex-end' : 'align-items:flex-start' }}">
                                <div class="pm-meta mb-1">
                                    <strong t-esc="authorName(c)"/>
                                    <span class="text-muted small ms-2" t-esc="formatDate(c.create_date)"/>
                                </div>
                                <div t-attf-class="pm-bubble {{ isOwn(c) ? 'pm-bubble-own' : 'pm-bubble-other' }}">
                                    <t t-if="c.message">
                                        <div t-out="messageHtml(c)"/>
                                    </t>
                                    <t t-if="c.file_name">
                                        <div class="mt-1 pt-1 border-top small">
                                            <a t-att-href="downloadUrl(c)"
                                               target="_blank"
                                               class="text-muted text-decoration-none">
                                                <i class="fa fa-download me-1"/>
                                                <t t-esc="c.file_name"/>
                                            </a>
                                        </div>
                                    </t>
                                </div>
                                <t t-if="isOwn(c)">
                                    <button class="btn btn-link btn-sm text-danger p-0 mt-1"
                                            t-on-click="() => this.onDelete(c)">
                                        <i class="fa fa-trash-o"/> Удалить
                                    </button>
                                </t>
                            </div>
                        </div>
                    </t>
                </t>
            </div>

            <!-- ===== ФОРМА ВВОДА ===== -->
            <div class="pm-input-area border rounded p-3 bg-white w-100">
                <div class="d-flex gap-2 align-items-start w-100">
                    <div class="pm-avatar pm-avatar-self flex-shrink-0">
                        <t t-esc="currentUserName ? currentUserName[0].toUpperCase() : '?'"/>
                    </div>
                    <textarea
                        class="form-control"
                        rows="2"
                        placeholder="Напишите комментарий..."
                        t-on-input="(ev) => { this.state.newMessage = ev.target.value; }"
                        t-att-value="state.newMessage"/>
                </div>

                <div class="d-flex align-items-center gap-2 mt-2">
                    <label class="btn btn-outline-secondary btn-sm mb-0">
                        <i class="fa fa-paperclip me-1"/>Файл
                        <input type="file" class="d-none" t-on-change="onFileChange"/>
                    </label>
                    <t t-if="state.fileName">
                        <span class="small text-muted">
                            <i class="fa fa-file-o me-1"/><t t-esc="state.fileName"/>
                        </span>
                        <button class="btn btn-link btn-sm text-danger p-0"
                                t-on-click="clearFile">
                            <i class="fa fa-times"/>
                        </button>
                    </t>
                    <button class="btn btn-primary btn-sm ms-auto"
                            t-on-click="onSubmit"
                            t-att-disabled="state.submitting">
                        <i class="fa fa-paper-plane me-1"/>
                        <t t-if="state.submitting">Отправка...</t>
                        <t t-else="">Отправить</t>
                    </button>
                </div>
            </div>

        </div>
    </t>
</templates>
