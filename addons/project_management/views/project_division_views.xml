<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_university_division_list" model="ir.ui.view">
            <field name="name">university.project.division.list</field>
            <field name="model">university.project.division</field>
            <field name="arch" type="xml">
                <list string="Подразделения" editable="bottom">
                    <field name="code" string="Код"/>
                    <field name="name" string="Наименование"/>
                </list>
            </field>
        </record>

        <record id="view_university_division_form" model="ir.ui.view">
            <field name="name">university.project.division.form</field>
            <field name="model">university.project.division</field>
            <field name="arch" type="xml">
                <form string="Подразделение">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Наименование подразделения"/>
                            </h1>
                        </div>
                        <group>
                            <field name="code" string="Код подразделения"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_university_project_division" model="ir.actions.act_window">
            <field name="name">Подразделения</field>
            <field name="res_model">university.project.division</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
