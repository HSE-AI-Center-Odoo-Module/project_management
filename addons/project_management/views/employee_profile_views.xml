<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===== EMPLOYEE PROFILE — FORM VIEW ===== -->
        <record id="view_employee_profile_form" model="ir.ui.view">
            <field name="name">university.employee.profile.form</field>
            <field name="model">university.employee.profile</field>
            <field name="arch" type="xml">
                <form string="Профиль сотрудника">
                    <sheet>

                        <!-- Title: user name -->
                        <div class="oe_title">
                            <label for="user_id"/>
                            <h1>
                                <field name="user_id"
                                       options="{'no_create': True, 'no_open': True}"
                                       readonly="1"/>
                            </h1>
                        </div>

                        <!-- Section: Position & Organisation + Workload -->
                        <group string="Должность и организация" name="group_position">
                            <group>
                                <field name="position"/>
                                <field name="department"/>
                            </group>
                            <group string="Загрузка">
                                <field name="project_count" readonly="1"/>
                                <field name="active_task_count" readonly="1"/>
                                <field name="workload_percent" readonly="1"/>
                            </group>
                        </group>

                        <!-- Section: Academic Profile -->
                        <group string="Академический профиль" name="group_academic">
                            <group>
                                <field name="degree"/>
                                <field name="academic_direction"/>
                                <field name="specialization"/>
                            </group>
                        </group>

                        <!-- Tabs -->
                        <notebook>

                            <!-- Certifications -->
                            <page string="Сертификаты и квалификации" name="page_certifications">
                                <field name="certification_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="issuer"/>
                                        <field name="issue_date"/>
                                        <field name="expiry_date"/>
                                        <field name="file_data" widget="binary"
                                               filename="file_name" string="Файл"/>
                                        <field name="file_name" column_invisible="True"/>
                                    </list>
                                </field>
                            </page>

                            <!-- Project history (read-only) -->
                            <page string="Проектный опыт" name="page_projects">
                                <field name="project_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="project_status"/>
                                        <field name="project_date_start"/>
                                        <field name="project_date_end"/>
                                    </list>
                                </field>
                            </page>

                        </notebook>

                    </sheet>
                </form>
            </field>
        </record>

        <!-- ===== EMPLOYEE PROFILE — LIST VIEW (admin menu) ===== -->
        <record id="view_employee_profile_list" model="ir.ui.view">
            <field name="name">university.employee.profile.list</field>
            <field name="model">university.employee.profile</field>
            <field name="arch" type="xml">
                <list string="Профили сотрудников">
                    <field name="user_id"/>
                    <field name="position"/>
                    <field name="department"/>
                    <field name="degree"/>
                    <field name="academic_direction"/>
                    <field name="active_task_count" string="Задач"/>
                    <field name="workload_percent" string="Загрузка %"/>
                </list>
            </field>
        </record>

        <!-- ===== EMPLOYEE PROFILE — SEARCH VIEW ===== -->
        <record id="view_employee_profile_search" model="ir.ui.view">
            <field name="name">university.employee.profile.search</field>
            <field name="model">university.employee.profile</field>
            <field name="arch" type="xml">
                <search string="Профили сотрудников">
                    <field name="user_id"/>
                    <field name="degree"/>
                    <field name="academic_direction"/>
                    <field name="department"/>
                    <separator/>
                    <filter string="Бакалавр" name="degree_bachelor"
                            domain="[('degree', '=', 'bachelor')]"/>
                    <filter string="Магистр" name="degree_master"
                            domain="[('degree', '=', 'master')]"/>
                    <filter string="Кандидат наук" name="degree_candidate"
                            domain="[('degree', '=', 'candidate')]"/>
                    <filter string="Доктор наук" name="degree_doctor"
                            domain="[('degree', '=', 'doctor')]"/>
                    <group expand="0" string="Группировать по">
                        <filter string="Степень" name="group_degree" context="{'group_by': 'degree'}"/>
                        <filter string="Кафедра" name="group_department" context="{'group_by': 'department'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ===== EMPLOYEE PROFILE — ACTION ===== -->
        <record id="action_employee_profiles" model="ir.actions.act_window">
            <field name="name">Профили сотрудников</field>
            <field name="res_model">university.employee.profile</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Профили сотрудников ещё не созданы.
                </p>
            </field>
        </record>

    </data>
</odoo>
