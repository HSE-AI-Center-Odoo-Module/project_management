<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ========== PROJECT CUSTOMER - LIST VIEW ========== -->
        <record id="view_university_project_customer_list" model="ir.ui.view">
            <field name="name">university.project.customer.list</field>
            <field name="model">university.project.customer</field>
            <field name="arch" type="xml">
                <list string="Заказчики" editable="bottom">
                    <field name="name"/>
                    <field name="contact_person"/>
                    <field name="email"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- ========== PROJECT CUSTOMER - FORM VIEW ========== -->
        <record id="view_university_project_customer_form" model="ir.ui.view">
            <field name="name">university.project.customer.form</field>
            <field name="model">university.project.customer</field>
            <field name="arch" type="xml">
                <form string="Заказчик">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Например: Министерство науки"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="contact_person"/>
                                <field name="email" widget="email"/>
                            </group>
                            <group>
                                <field name="active" widget="boolean_toggle"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ========== PROJECT CUSTOMER - SEARCH VIEW ========== -->
        <record id="view_university_project_customer_search" model="ir.ui.view">
            <field name="name">university.project.customer.search</field>
            <field name="model">university.project.customer</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="contact_person"/>
                    <filter string="В архиве" name="archived" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <!-- ========== PROJECT CUSTOMER - ACTION ========== -->
        <record id="action_university_project_customer" model="ir.actions.act_window">
            <field name="name">Заказчики</field>
            <field name="res_model">university.project.customer</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>