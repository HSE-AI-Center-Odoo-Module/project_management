<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ========== PROJECT STAGE - LIST VIEW ========== -->
        <record id="view_university_project_stage_list" model="ir.ui.view">
            <field name="name">university.project.stage.list</field>
            <field name="model">university.project.stage</field>
            <field name="arch" type="xml">
                <list string="Project Stages"
                      decoration-success="status == 'in_progress'"
                      decoration-muted="status == 'done'"
                      decoration-danger="status == 'cancel'">
                    <field name="sequence" widget="handle"/>
                    <field name="name" string="Stage Name"/>
                    <field name="status" widget="badge"
                           decoration-info="status == 'draft'"
                           decoration-success="status == 'in_progress'"
                           decoration-muted="status == 'done'"
                           decoration-danger="status == 'cancel'"/>
                    <field name="date_start" widget="date" optional="show"/>
                    <field name="date_end" widget="date" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ========== PROJECT STAGE - FORM VIEW ========== -->
        <record id="view_university_project_stage_form" model="ir.ui.view">
            <field name="name">university.project.stage.form</field>
            <field name="model">university.project.stage</field>
            <field name="arch" type="xml">
                <form string="Project Stage">
                    <header>
                        <button name="action_start" string="Start" type="object"
                            class="btn-primary"
                            invisible="status != 'draft' or not is_manager"/>
                        <button name="action_done" string="Complete" type="object"
                            class="btn-primary"
                            invisible="status != 'in_progress' or not is_manager"/>
                        <button name="action_cancel" string="Cancel" type="object"
                            invisible="status not in ('draft', 'in_progress') or not is_manager"/>
                        <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            invisible="status != 'cancel' or not is_manager"/>
                        <field name="status" widget="statusbar" readonly="1"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button" type="object" name="action_view_tasks" icon="fa-tasks">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Tasks</span>
                                </div>
                            </button>
                        </div>

                        <field name="is_manager" invisible="1"/>

                        <div class="oe_title">
                            <label for="name" string="Название этапа" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="Например: Разработка" readonly="not is_manager"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="project_id" readonly="1" options="{'no_open': True}"/>
                            </group>
                            <group>
                                <label for="date_start" string="Сроки выполнения"/>
                                <div class="o_row">
                                    <field name="date_start" widget="date" placeholder="Начало" readonly="not is_manager"/>
                                    <i class="fa fa-long-arrow-right mx-2" title="по" role="img" aria-label="по"/>
                                    <field name="date_end" widget="date" placeholder="Конец" readonly="not is_manager" decoration-danger="date_end &lt; date_start"/>
                                </div>
                                <field name="date_error_msg" nolabel="1" class="text-danger fw-bold" invisible="not date_error_msg" colspan="2"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Описание" name="description">
                                <field name="description" nolabel="1" placeholder="Добавьте описание этапа..." readonly="not is_manager"/>
                            </page>

                            <page string="Attachments" name="university_project_docs">
                                <field name="document_ids" readonly="not is_manager" context="{'form_view_ref': 'project_management.view_university_project_document_form'}">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="version_label" readonly="1"/>
                                        <field name="file_data" widget="binary" filename="file_name"/>
                                        <field name="file_name" column_invisible="True"/>
                                        <field name="uploaded_by" readonly="1"/>
                                        <field name="uploaded_at" readonly="1"/>
                                        <button
                                            type="object"
                                            name="action_create_new_version"
                                            string="New Version"
                                            icon="fa-files-o"
                                            class="btn-link"
                                            invisible="not id or not is_latest_version"/>
                                        <field name="is_latest_version" column_invisible="True"/>
                                    </list>
                                </field>
                            </page>

                            <page string="История" name="history">
                                <field name="history_ids" readonly="1" options="{'no_create': True}">
                                    <list create="0" edit="0" delete="0">
                                        <field name="date"/>
                                        <field name="user_id" widget="many2one_avatar_user"/>
                                        <field name="name"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
